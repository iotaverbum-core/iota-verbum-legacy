{
  "name": "iota-witness-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app src --ext .ts,.tsx,.js,.jsx",
    "eas:configure": "eas build:configure",
    "eas:build:ios": "eas build --platform ios --profile production",
    "eas:build:android": "eas build --platform android --profile production",
    "eas:submit:ios": "eas submit --platform ios --profile production",
    "eas:submit:android": "eas submit --platform android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tanstack/react-query": "^5.62.9",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "uuid": "^11.0.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-expo": "^1.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "^5.7.2"
  }
}

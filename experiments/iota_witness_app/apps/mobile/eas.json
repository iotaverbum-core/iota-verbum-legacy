{
  "cli": {
    "version": ">= 13.2.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.edenwitness.app",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://edenwitness.app/privacy",
        "EXPO_PUBLIC_TERMS_URL": "https://edenwitness.app/terms",
        "EXPO_PUBLIC_LOCAL_CRISIS_HELP_URL": "https://edenwitness.app/help/local-crisis",
        "EXPO_PUBLIC_CONTACT_EMAIL": "support@edenwitness.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "release@edenwitness.app",
        "ascAppId": "6746239011",
        "appleTeamId": "A1B2C3D4E5"
      },
      "android": {
        "serviceAccountKeyPath": "./keys/google-play-service-account.json",
        "track": "production"
      }
    }
  }
}

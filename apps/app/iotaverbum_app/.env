# Copy this file to .env and fill in the appropriate values.

# OpenAI API key for GPT‑5.1
OPENAI_API_KEY=
# Preferred OpenAI model (default gpt-5.1)
OPENAI_MODEL=gpt-5.1

# Run without calling OpenAI (fake responses)
ATTESTATION_FAKE_MODE=1

# Slack configuration for alert system
SLACK_TOKEN=xoxb-your-slack-token
ALERT_CHANNEL_ID=alignment-alerts

# SMTP configuration for email alerts
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# Optional: Set NODE_ENV=production when deploying
NODE_ENV=development
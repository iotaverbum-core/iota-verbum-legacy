            "Preserves(Plead(Psalmist, YHWH, \"Be not far from me\", t_suffering), FaithfulDeliverer(YHWH))",
            "Preserves(Plead(Psalmist, YHWH, \"Be not far from me\", t_suffering), L(YHWH))"

  "claims": [
    {
      "id": "c1",
      "type": "hinge_candidate",
      "text": "Jesus' first sign turns purification water into wine, manifesting his glory so that his disciples believe.",
      "supported_by": [
        "e9",
        "e10",
        "e11",
        "e18",
        "e19",
        "e20",
        "m6"
      ],
      "inference": false
    },
    {
      "id": "c2",
      "type": "scene_theology",
      "text": "Jesus' 'hour not yet' introduces a timing boundary: he helps real need, yet signals a deeper approaching climax not controlled by human urgency.",
      "supported_by": [
        "e6",
        "e7",
        "m2"
      ],
      "inference": true
    },
    {
      "id": "c3",
      "type": "hinge_candidate",
      "text": "Jesus cleanses the temple, claiming it as his Father's house; his authority is challenged, and he speaks of his body as the true temple to be raised.",
      "supported_by": [
        "e27",
        "e28",
        "e29",
        "e30",
        "e31",
        "e32",
        "e34",
        "e35",
        "e37",
        "m9",
        "m11"
      ],
      "inference": false
    },
    {
      "id": "c4",
      "type": "scene_theology",
      "text": "John distinguishes 'belief in his name' from Jesus entrusting himself: signs can produce assent, but Jesus knows what is in man and refuses shallow possession.",
      "supported_by": [
        "e42",
        "e43",
        "e44",
        "e46",
        "m12"
      ],
      "inference": true
    }
  ],
  "hinge": {
    "themes": [
      "signs",
      "glory",
      "hour",
